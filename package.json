{
  "name": "laurenyu-portfolio",
  "version": "1.0.0",
  "description": "A sleek and tech-savvy portfolio website for showcasing projects and skills.",
  "main": "src/index.html",
  "scripts": {
    "build": "npm run build-css && npm run build-js",
    "build-css": "node-sass src/styles/main.scss public/styles/main.css",
    "build-js": "babel src/scripts --out-dir public/scripts",
    "start": "live-server public",
    "test": "echo \"No tests specified\" && exit 0"
  },
  "author": "Lauren Yu",
  "license": "MIT",
  "dependencies": {
    "node-sass": "^6.0.0",
    "babel-cli": "^6.26.0",
    "babel-preset-env": "^1.7.0",
    "live-server": "^1.2.1"
  },
  "devDependencies": {
    "eslint": "^7.32.0",
    "eslint-config-airbnb-base": "^15.0.0",
    "eslint-plugin-import": "^2.24.2"
  },
  "keywords": [
    "portfolio",
    "website",
    "projects",
    "web components",
    "JavaScript",
    "SCSS"
  ]
}